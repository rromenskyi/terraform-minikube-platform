# Cloudflare
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_ZONE_ID=your-primary-zone-id
CLOUDFLARE_TUNNEL_SECRET=any-random-string-min-32-chars

# Let's Encrypt
LETSENCRYPT_EMAIL=your-email@example.com

# --- Persistent-storage prefix ---------------------------------------------
# HOST_VOLUME_PATH is used verbatim by hostPath PersistentVolumes, so it has to
# resolve to a real, writable directory from the Kubernetes node's point of
# view. Pick the value that matches your distribution:
#
#   • Native k3s on Linux (Option B in main.tf) — the kubelet sees the host
#     FS directly, so use any host directory:
#       HOST_VOLUME_PATH=/data/vol
#
#   • minikube on Linux with --driver=none — same as k3s, host = node:
#       HOST_VOLUME_PATH=/data/vol
#
#   • minikube on macOS (Docker driver, Option A default) — the minikube VM
#     auto-mounts /Users from the Mac host as /minikube-host inside the node.
#     Put your data at /Users/Shared/vol on the Mac and point the variable at
#     its in-VM path:
#       HOST_VOLUME_PATH=/minikube-host/Shared/vol
#
#   • minikube on Linux with --driver=docker — minikube does NOT auto-mount
#     the host FS; set up a `minikube mount <host-dir>:<node-dir>` sidecar
#     and point HOST_VOLUME_PATH at <node-dir>.
#
# Default if unset: /data/vol (see variables.tf).
# HOST_VOLUME_PATH=/data/vol

# --- k3s distribution (only when Option B is active in main.tf) -------------
# TF_VAR_ssh_host=127.0.0.1
# TF_VAR_ssh_port=22
# TF_VAR_ssh_user=your-linux-user
# TF_VAR_ssh_private_key_path=/home/your-linux-user/.ssh/id_ed25519

# (Optional) Backblaze B2 for remote state
# AWS_ACCESS_KEY_ID=your-backblaze-key-id
# AWS_SECRET_ACCESS_KEY=your-backblaze-application-key
# AWS_REGION=us-east-1
# B2_BUCKET=tfstate-unique
# B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
