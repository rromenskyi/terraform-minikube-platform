# Backend credentials for Backblaze B2 (S3-compatible).
AWS_ACCESS_KEY_ID=your-backblaze-key-id
AWS_SECRET_ACCESS_KEY=your-backblaze-application-key
AWS_REGION=us-east-1
B2_BUCKET=tfstate-unique
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com

# Export this file before running Terraform:
# set -a; source .env; set +a

TF_VAR_cluster_name=minikube
TF_VAR_kubernetes_version=stable
TF_VAR_letsencrypt_email=your-email@example.com
TF_VAR_cloudflare_api_token=your-cloudflare-api-token
TF_VAR_cloudflare_account_id=your-cloudflare-account-id
TF_VAR_cloudflare_zone_id=your-cloudflare-zone-id
# Apex domain used to build tunnel ingress hostnames (e.g. `example.com`
# → `echo.example.com`, `grafana.example.com`, ...). Must match the zone
# above. No default — pick your own.
TF_VAR_cloudflare_tunnel_domain=example.com

# --- k3s distribution (only when Option B is active in main.tf) -------------
# TF_VAR_ssh_host=127.0.0.1
# TF_VAR_ssh_port=22
# TF_VAR_ssh_user=your-linux-user
# TF_VAR_ssh_private_key_path=/home/your-linux-user/.ssh/id_ed25519

# Shared tunnel token for both Terraform and the Cloudflared secret manifest.
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token
TF_VAR_cloudflare_tunnel_token=${CLOUDFLARE_TUNNEL_TOKEN}
