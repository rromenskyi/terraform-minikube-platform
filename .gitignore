*.tfvars
*.tfvars.json

# Local cluster access
kubeconfig*.yaml

# Kubernetes secrets
manifests/**/secret*.yaml

# Local terraform wrapper
tf

*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl
.DS_Store
