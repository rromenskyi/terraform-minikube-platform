# Domain configuration example.
# Copy this file without the .example suffix and adjust for your domain:
#   cp example.com.yaml.example mydomain.com.yaml
#
# Real tenant files are gitignored (see .gitignore); only the
# `.yaml.example` templates are tracked.

name: example.com                              # Domain name (used in hostnames)
slug: example-com                              # URL-safe slug (used in namespace names)
cloudflare_zone_id: "your-zone-id-from-cf"     # Cloudflare Zone ID for this domain

# (Optional) Manual DNS records. Domain-scoped (not env-scoped) — these
# describe the zone, not per-env routing. The platform automatically
# emits a CNAME for every `envs.*.routes:` entry below pointing at the
# Cloudflare Tunnel; use `dns:` here for everything else (MX/SPF/DKIM/
# DMARC for mail, SRV for SIP/XMPP, apex A when a host has a public
# WAN IP for non-HTTP, third-party verification TXT, etc.).
#
# Each entry:
#   name     — record name. "@" or "" = apex; otherwise relative to the zone.
#   type     — A | AAAA | CNAME | MX | TXT | SRV | NS | CAA | PTR | LOC.
#   content  — string value (required for non-SRV/CAA/LOC types).
#   data     — structured object (required for SRV/CAA/LOC; replaces content).
#   ttl      — seconds. Default 1 = "Auto" on Cloudflare Free.
#   proxied  — orange-cloud (CF proxy). Only valid for A/AAAA/CNAME. Default false.
#   priority — for MX records. Default null.
#   comment  — free-text shown in CF UI for context.
#
# dns:
#   # Mail — external relay holds the public IP and the MX, since
#   # residential ISPs block inbound :25 and CF Tunnel doesn't forward TCP.
#   - name: "@"
#     type: MX
#     content: "mail-relay.example.net"
#     priority: 10
#   - name: "@"
#     type: TXT
#     content: "v=spf1 include:mail-relay.example.net ~all"
#     comment: "SPF — authorise mail-relay to send as @example.com"
#   - name: _dmarc
#     type: TXT
#     content: "v=DMARC1; p=none; rua=mailto:postmaster@example.com"
#
#   # Apex A — when home box has a public WAN IP exposed (e.g. SIP UDP).
#   - name: "@"
#     type: A
#     content: "203.0.113.5"
#     proxied: false               # CF Tunnel proxy is HTTP-only; UDP needs unproxied
#
#   # SIP service discovery — sipmesh sip-proxy listens on UDP 5060 at sip.example.com.
#   - name: _sip._udp
#     type: SRV
#     data:
#       priority: 10
#       weight:   100
#       port:     5060
#       target:   sip.example.com
#
#   # Third-party verification (Bing webmaster, GitHub Pages, etc.)
#   - name: "@"
#     type: TXT
#     content: "google-site-verification=AbCdEf..."

# `envs` is a map of env name → per-env routing config.
# Hostnames and components are decoupled:
#   - the map key is the HOST PREFIX    ("" = bare apex, "www" = www.example.com)
#   - the map value is the COMPONENT NAME (resolved from config/components/<name>.yaml)
# A component is deployed iff at least one route points at it. The same
# component can back multiple hosts; different hosts can back different
# components.
#
# Final hostname per route: "{host_prefix}.{domain}" literally, with
# "" collapsing to the apex. The env name is NOT injected into the
# hostname — if two envs need distinct URLs, spell out the subdomain
# in the key (e.g. `api.dev: whoami` → api.dev.example.com).
envs:
  prod:
    routes:
      "":    web          # example.com              → web
      www:   web          # www.example.com          → web
      api:   whoami       # api.example.com          → whoami
      debug: echo         # debug.example.com        → echo
      # First-party app — inline `kind: app` definition right here,
      # no separate `config/components/<name>.yaml`. See `components:`
      # block below for the matching shape.
      app:   my-app       # app.example.com          → my-app (kind: app)

    # Per-route component overrides AND inline component definitions.
    # The per-project shallow merge order is:
    #   1. defaults (kind=deployment, etc.)
    #   2. config/components/<name>.yaml if it exists (generic templates)
    #   3. this `components:` block (operator-specific overrides + inline definitions)
    # First-party `kind: app` components belong here — they reference an
    # operator-private image (ghcr.io/<your-handle>/...), an OIDC redirect
    # URI tied to your domain, and a role taxonomy you own. There is no
    # generic template to fall back on, so the whole spec lives inline.
    components:
      my-app:
        kind: app
        image: ghcr.io/your-handle/my-app:latest
        port:  3000
        replicas: 1
        resources:
          requests: { cpu: 100m, memory: 128Mi }
          limits:   { cpu: 500m, memory: 512Mi }
        health_path: /
        # Public-origin envs for SSR frameworks behind cloudflared —
        # without these Auth.js / similar generate http:// callback
        # URLs that the IdP rejects.
        env_static:
          ORIGIN:           https://app.example.com
          AUTH_URL:         https://app.example.com
          PROTOCOL_HEADER:  x-forwarded-proto
          HOST_HEADER:      x-forwarded-host
        oidc:
          enabled: true
          project: my-app
          redirect_paths:
            - /auth/callback/zitadel
          post_logout_paths:
            - /
          roles:
            - { key: admin, display_name: "Admin" }
            - { key: user,  display_name: "User"  }

  # Optional additional env. Pick prefixes that don't collide with prod:
  # dev:
  #   routes:
  #     api.dev:   whoami   # api.dev.example.com     → whoami
  #     admin.dev: echo     # admin.dev.example.com   → echo

# (Optional) Override the default ResourceQuota for this project's namespace.
# Applies per-env if placed under `envs.<env>.limits`, or project-wide here.
# limits:
#   cpu: "2"
#   memory: "4Gi"
